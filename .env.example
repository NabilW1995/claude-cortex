# Projekt-Konfiguration
# Kopiere diese Datei zu .env und fülle die Werte aus
# NEVER commit die .env Datei!

# App
APP_NAME=
APP_URL=http://localhost:3000
NODE_ENV=development

# Datenbank (wenn benötigt)
DATABASE_URL=

# Authentication (wenn benötigt)
AUTH_SECRET=

# Deployment
VERCEL_TOKEN=
NETLIFY_TOKEN=

# Externe APIs (wenn benötigt)
# API_KEY=
