# Projekt-Konfiguration
# Kopiere diese Datei zu .env und fülle die Werte aus
# NEVER commit die .env Datei!

# App
APP_NAME=
APP_URL=http://localhost:3000
NODE_ENV=development

# Datenbank (wenn benötigt)
DATABASE_URL=

# Authentication (wenn benötigt)
AUTH_SECRET=

# Deployment
VERCEL_TOKEN=
NETLIFY_TOKEN=

# Externe APIs (wenn benötigt)
# API_KEY=

# Telegram Bot (Cortex Team Bot)
# Erstelle einen Bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
TELEGRAM_LOGIN_CHAT_ID=
TELEGRAM_LOGIN_THREAD_ID=

# Cortex Worker (Team Bot Backend)
CORTEX_WORKER_URL=https://cortex-team-bot.twilight-resonance-f2fc.workers.dev
CORTEX_PROJECT_ID=
